// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ItemStatus {
  neu_erfasst
  zu_pruefen
  zu_reinigen
  ready_fuer_fotos
  fotografiert
  gelistet
  reserviert
  verkauft
  verpackt
  versendet
  abgeschlossen
  bundle
  spende
  entsorgt
}

enum ItemCondition {
  neu
  sehr_gut
  gut
  akzeptabel
}

enum StorageLocationType {
  stange
  regal
  box
  versandzone
  sonstiges
}

enum ShipmentStatus {
  vorbereitet
  versendet
  zugestellt
  problem
}

model Item {
  id                  String          @id @default(uuid())
  title               String
  category            String
  brand               String?
  size                String?
  condition           ItemCondition   @default(gut)
  notes               String?
  purchasePrice       Decimal         @db.Decimal(10, 2)
  targetPrice         Decimal?        @db.Decimal(10, 2)
  status              ItemStatus      @default(neu_erfasst)
  storageLocation     StorageLocation? @relation(fields: [storageLocationId], references: [id])
  storageLocationId   String?
  platform            Platform?       @relation(fields: [platformId], references: [id])
  platformId          String?
  sale                Sale?
  statusHistory       StatusHistory[]
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
}

model Sale {
  id            String    @id @default(uuid())
  item          Item      @relation(fields: [itemId], references: [id])
  itemId        String    @unique
  platform      Platform  @relation(fields: [platformId], references: [id])
  platformId    String
  salePrice     Decimal   @db.Decimal(10, 2)
  platformFee   Decimal   @default(0) @db.Decimal(10, 2)
  shippingCost  Decimal   @default(0) @db.Decimal(10, 2)
  otherCosts    Decimal   @default(0) @db.Decimal(10, 2)
  profit        Decimal   @db.Decimal(10, 2)
  soldAt        DateTime  @default(now())
  buyerNote     String?
  shipment      Shipment?
}

model Shipment {
  id              String         @id @default(uuid())
  sale            Sale           @relation(fields: [saleId], references: [id])
  saleId          String         @unique
  trackingNumber  String?
  carrier         String?
  status          ShipmentStatus @default(vorbereitet)
  shippedAt       DateTime?
  deliveredAt     DateTime?
}

model StorageLocation {
  id          String              @id @default(uuid())
  code        String              @unique
  description String?
  type        StorageLocationType @default(sonstiges)
  isActive    Boolean             @default(true)
  items       Item[]
}

model Platform {
  id            String  @id @default(uuid())
  name          String  @unique
  defaultFeePct Decimal? @db.Decimal(5, 2)
  url           String?
  isActive      Boolean @default(true)
  items         Item[]
  sales         Sale[]
}

model Category {
  id       String @id @default(uuid())
  name     String @unique
  sortOrder Int   @default(0)
}

model StatusHistory {
  id          String    @id @default(uuid())
  item        Item      @relation(fields: [itemId], references: [id])
  itemId      String
  fromStatus  String
  toStatus    String
  note        String?
  changedAt   DateTime  @default(now())
}

